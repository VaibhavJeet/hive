# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files
*.py text
*.dart text
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text
*.yml text
*.yaml text
*.html text
*.css text
*.scss text

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary

# Flutter specific
*.lock text

# Linguist overrides
docs/* linguist-documentation
*.md linguist-documentation
