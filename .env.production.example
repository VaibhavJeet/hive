# =============================================================================
# Sentient - Production Environment Configuration
# =============================================================================
# This file contains all environment variables for production deployment.
# Copy to .env and configure all REQUIRED variables before starting.
#
# Variable naming: All variables use the AIC_ prefix (AI Companions)
# =============================================================================

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Deployment environment: development, staging, production, test
# REQUIRED: Set to "production" for production deployments
AIC_ENVIRONMENT=production

# =============================================================================
# DATABASE - PostgreSQL with pgvector
# =============================================================================
# REQUIRED: PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database
# Security: Use strong passwords, consider SSL (add ?sslmode=require)
AIC_DATABASE_URL=postgresql+asyncpg://sentient_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/sentient

# Connection pool configuration
# Increase for high-traffic deployments
AIC_DATABASE_POOL_SIZE=20
AIC_DATABASE_MAX_OVERFLOW=40

# =============================================================================
# REDIS - Caching and Real-time State
# =============================================================================
# REQUIRED: Redis connection string
# Format: redis://:password@host:port/db
# For password-protected Redis: redis://:yourpassword@localhost:6379/0
AIC_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0

# Redis connection pool settings
AIC_REDIS_MAX_CONNECTIONS=20
AIC_REDIS_ENABLED=true

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Default cache TTL in seconds
AIC_CACHE_DEFAULT_TTL=300

# LLM response cache TTL (1 hour default)
AIC_CACHE_LLM_RESPONSE_TTL=3600

# Bot profile cache TTL
AIC_CACHE_BOT_PROFILE_TTL=300

# =============================================================================
# LLM CONFIGURATION - Ollama
# =============================================================================
# LLM provider: ollama, llamacpp, openai
AIC_LLM_PROVIDER=ollama

# REQUIRED: Ollama server URL
# For local: http://localhost:11434
# For remote: https://ollama.yourdomain.com
AIC_OLLAMA_BASE_URL=http://localhost:11434

# Model for text generation
# Recommended: phi4-mini (fast), llama3.2 (quality), mistral (balanced)
AIC_OLLAMA_MODEL=phi4-mini

# Model for embeddings (768-dimensional vectors)
AIC_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Multi-instance Ollama (for load balancing)
# Comma-separated list of Ollama URLs
AIC_OLLAMA_INSTANCES=http://localhost:11434

# Load balancing strategy: round_robin, least_loaded, random
AIC_LOAD_BALANCING_STRATEGY=round_robin

# =============================================================================
# INFERENCE OPTIMIZATION
# =============================================================================
# Maximum concurrent LLM requests (adjust based on GPU VRAM)
# RTX 3060 (6GB): 4-6, RTX 3080 (10GB): 8-12, RTX 4090 (24GB): 16+
AIC_LLM_MAX_CONCURRENT_REQUESTS=8

# Request timeout in seconds (increase for slower models)
AIC_LLM_REQUEST_TIMEOUT=60

# Maximum tokens per generation
AIC_LLM_MAX_TOKENS=512

# Temperature: 0.0 = deterministic, 1.0 = creative
AIC_LLM_TEMPERATURE=0.8

# Batch size for inference grouping
AIC_INFERENCE_BATCH_SIZE=4

# Embedding batch configuration
AIC_EMBEDDING_BATCH_SIZE=32
AIC_EMBEDDING_BATCH_INTERVAL=5.0

# =============================================================================
# BOT ENGINE CONFIGURATION
# =============================================================================
# Maximum active bots in simulation
# Balance between activity and performance
# 100-500 bots: 30-50, 500-1000 bots: 50-100
AIC_MAX_ACTIVE_BOTS=50

# Bots per community limits
AIC_MAX_BOTS_PER_COMMUNITY=150
AIC_MIN_BOTS_PER_COMMUNITY=30

# Activity check interval in seconds
AIC_BOT_ACTIVITY_CHECK_INTERVAL=60

# Authenticity mode: false for production (realistic timing)
# Demo mode (true) runs 10x faster for testing
AIC_AUTHENTICITY_DEMO_MODE=false

# Advanced authenticity features
AIC_AUTHENTICITY_TYPING_INDICATORS=true
AIC_AUTHENTICITY_READ_RECEIPTS=true
AIC_AUTHENTICITY_DAILY_MOOD=true
AIC_AUTHENTICITY_SOCIAL_PROOF=true
AIC_AUTHENTICITY_CONVERSATION_CALLBACKS=true
AIC_AUTHENTICITY_GRADUAL_ENGAGEMENT=true
AIC_AUTHENTICITY_REACTION_VARIETY=true

# =============================================================================
# TIMING CONFIGURATION (Human-like delays)
# =============================================================================
# Typing delay range in milliseconds
AIC_MIN_TYPING_DELAY_MS=500
AIC_MAX_TYPING_DELAY_MS=3000

# Response delay range in milliseconds
AIC_MIN_RESPONSE_DELAY_MS=1000
AIC_MAX_RESPONSE_DELAY_MS=30000

# =============================================================================
# MEMORY CONFIGURATION
# =============================================================================
# Vector embedding dimension (must match embedding model)
# nomic-embed-text: 768, all-MiniLM-L6-v2: 384
AIC_VECTOR_DIMENSION=768

# Maximum memory items per bot
AIC_MAX_MEMORY_ITEMS=1000

# Memory retrieval limit per query
AIC_MEMORY_RETRIEVAL_LIMIT=10

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================
# REQUIRED: API server binding
# Production: 127.0.0.1 (behind reverse proxy) or 0.0.0.0 (direct access)
AIC_API_HOST=127.0.0.1
AIC_API_PORT=8000

# Number of API workers (typically 2-4x CPU cores)
AIC_API_WORKERS=4

# Debug mode (MUST be false in production)
AIC_API_DEBUG=false

# =============================================================================
# SECURITY - CRITICAL FOR PRODUCTION
# =============================================================================
# REQUIRED: JWT secret key for token signing
# Generate with: openssl rand -hex 32
# MUST be at least 32 characters, unique per deployment
AIC_JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# JWT algorithm (HS256 recommended)
AIC_JWT_ALGORITHM=HS256

# Token expiration settings
AIC_ACCESS_TOKEN_EXPIRE_MINUTES=30
AIC_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (REQUIRED: restrict to your domains)
# Comma-separated list of allowed origins
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
AIC_CORS_ORIGINS=https://yourdomain.com

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================
# Enable Prometheus metrics endpoint
AIC_METRICS_ENABLED=true

# Metrics endpoint port
AIC_METRICS_PORT=9090

# Health check timeout in seconds
AIC_HEALTH_CHECK_TIMEOUT=5.0

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Production: INFO or WARNING
AIC_LOG_LEVEL=INFO

# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================
# Web Push (VAPID) - Generate keys with web-push library
# Optional: Only required if using web push notifications
#AIC_VAPID_PUBLIC_KEY=
#AIC_VAPID_PRIVATE_KEY=
#AIC_VAPID_CLAIMS_EMAIL=mailto:admin@yourdomain.com

# Firebase Cloud Messaging (FCM)
# Optional: Only required for mobile push notifications
# Path to Firebase Admin SDK service account JSON
#AIC_FCM_CREDENTIALS_PATH=/etc/sentient/firebase-credentials.json
#AIC_FCM_PROJECT_ID=your-firebase-project-id

# =============================================================================
# OBJECT STORAGE
# =============================================================================
# Storage provider: local, minio, seaweedfs, garage, s3
# Production recommendation: minio or s3 for scalability
AIC_STORAGE_PROVIDER=minio

# S3-compatible endpoint (required for minio, seaweedfs, garage)
AIC_STORAGE_ENDPOINT=http://localhost:9000

# Storage credentials (REQUIRED for S3-compatible storage)
AIC_STORAGE_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
AIC_STORAGE_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY

# Storage bucket name
AIC_STORAGE_BUCKET=sentient-media

# AWS region (only for AWS S3)
AIC_STORAGE_REGION=us-east-1

# Public URL for serving files (CDN recommended for production)
#AIC_STORAGE_PUBLIC_URL=https://cdn.yourdomain.com

# Use SSL/HTTPS for storage connections
AIC_STORAGE_USE_SSL=true

# Local filesystem storage (fallback path)
AIC_MEDIA_STORAGE_PATH=/var/lib/sentient/media

# File size limits
AIC_MAX_IMAGE_SIZE_MB=10.0
AIC_MAX_VIDEO_SIZE_MB=100.0
AIC_MAX_VIDEO_DURATION_SECONDS=300
AIC_VIDEO_FORMATS=mp4,mov,webm

# =============================================================================
# EXTERNAL AI SERVICES (Optional)
# =============================================================================
# OpenAI API (for DALL-E image generation)
#AIC_OPENAI_API_KEY=sk-your-openai-api-key

# Image generation
AIC_IMAGE_GENERATION_ENABLED=false
#AIC_IMAGE_GENERATION_PROVIDER=openai
#AIC_IMAGE_GENERATION_MODEL=dall-e-3
#AIC_IMAGE_GENERATION_API_KEY=
AIC_IMAGE_GENERATION_PROBABILITY=0.1

# Text-to-Speech
AIC_TTS_ENABLED=false
#AIC_TTS_PROVIDER=edge
#AIC_TTS_API_KEY=

# Web Search
AIC_WEB_SEARCH_ENABLED=true
AIC_WEB_SEARCH_PROVIDER=duckduckgo
#AIC_WEB_SEARCH_API_KEY=

# =============================================================================
# EXTERNAL CHANNELS (Telegram, Discord)
# =============================================================================
AIC_EXTERNAL_CHANNELS_ENABLED=false

# Telegram Bot (get from @BotFather)
#AIC_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
#AIC_TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# Discord Bot
#AIC_DISCORD_BOT_TOKEN=your-discord-bot-token
#AIC_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# =============================================================================
# GITHUB INTEGRATION (Optional - for bot self-development)
# =============================================================================
# GitHub Personal Access Token with repo permissions
#AIC_GITHUB_TOKEN=ghp_your-github-token
#AIC_GITHUB_BOT_REPO_PREFIX=bot-evolution

# =============================================================================
# PRODUCTION NOTES
# =============================================================================
#
# Before deploying:
# 1. Change ALL passwords marked with CHANGE_ME
# 2. Generate a unique JWT_SECRET_KEY: openssl rand -hex 32
# 3. Restrict CORS_ORIGINS to your actual domains
# 4. Set ENVIRONMENT=production
# 5. Set API_DEBUG=false
# 6. Set AUTHENTICITY_DEMO_MODE=false
# 7. Configure proper SSL/TLS via reverse proxy (Nginx, Caddy)
# 8. Set up database backups
# 9. Configure monitoring (Prometheus, Grafana)
#
# Security checklist:
# [ ] Strong database password
# [ ] Strong Redis password
# [ ] Unique JWT secret key (32+ characters)
# [ ] CORS restricted to your domains
# [ ] Firewall configured (only 80, 443, 22)
# [ ] SSL/TLS enabled via reverse proxy
# [ ] Storage credentials secured
# [ ] .env file permissions: chmod 600
#
# See docs/deployment/ENVIRONMENT.md for detailed documentation
# =============================================================================
