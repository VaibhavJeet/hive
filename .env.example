# =============================================================================
# Hive Social Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# All variables are prefixed with AIC_ (AI Companions)

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string (with asyncpg driver)
AIC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_companions

# Redis connection string for caching and real-time state
AIC_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# LLM provider: ollama or llamacpp
AIC_LLM_PROVIDER=ollama

# Ollama server URL
AIC_OLLAMA_BASE_URL=http://localhost:11434

# Ollama model for text generation (phi4-mini is lightweight and fast)
# Other options: llama3.2, mistral, gemma2
AIC_OLLAMA_MODEL=phi4-mini

# Ollama model for embeddings (768-dimensional vectors)
AIC_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# INFERENCE OPTIMIZATION
# =============================================================================
# Maximum concurrent LLM requests (reduce if Ollama is overloaded)
AIC_LLM_MAX_CONCURRENT_REQUESTS=8

# Request timeout in seconds (increase for slower hardware)
AIC_LLM_REQUEST_TIMEOUT=30

# Maximum tokens per generation
AIC_LLM_MAX_TOKENS=512

# Default temperature (0.0 = deterministic, 1.0 = creative)
AIC_LLM_TEMPERATURE=0.8

# Batch size for inference grouping
AIC_INFERENCE_BATCH_SIZE=4

# =============================================================================
# BOT CONFIGURATION
# =============================================================================
# Maximum active bots (reduce for better performance, increase for more activity)
AIC_MAX_ACTIVE_BOTS=12

# Bots per community
AIC_MAX_BOTS_PER_COMMUNITY=150
AIC_MIN_BOTS_PER_COMMUNITY=30

# Activity check interval in seconds
AIC_BOT_ACTIVITY_CHECK_INTERVAL=60

# =============================================================================
# GITHUB INTEGRATION (Optional - for bot self-development)
# =============================================================================
# GitHub Personal Access Token with repo permissions
# Leave empty to disable GitHub features
AIC_GITHUB_TOKEN=

# Prefix for bot-created repositories
AIC_GITHUB_BOT_REPO_PREFIX=bot-evolution

# =============================================================================
# TIMING CONFIGURATION (Human-like delays)
# =============================================================================
# Typing delay range in milliseconds
AIC_MIN_TYPING_DELAY_MS=500
AIC_MAX_TYPING_DELAY_MS=3000

# Response delay range in milliseconds
AIC_MIN_RESPONSE_DELAY_MS=1000
AIC_MAX_RESPONSE_DELAY_MS=30000

# =============================================================================
# MEMORY CONFIGURATION
# =============================================================================
# Vector embedding dimension (must match embedding model)
AIC_VECTOR_DIMENSION=768

# Maximum memory items per bot
AIC_MAX_MEMORY_ITEMS=1000

# Memory retrieval limit per query
AIC_MEMORY_RETRIEVAL_LIMIT=10

# =============================================================================
# API CONFIGURATION
# =============================================================================
# API server host and port
AIC_API_HOST=0.0.0.0
AIC_API_PORT=8000

# Number of API workers (for production)
AIC_API_WORKERS=4

# =============================================================================
# SECURITY
# =============================================================================
# JWT secret key (CHANGE IN PRODUCTION!)
AIC_JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# JWT algorithm
AIC_JWT_ALGORITHM=HS256

# Token expiration
AIC_ACCESS_TOKEN_EXPIRE_MINUTES=30
AIC_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS origins (comma-separated, or * for all)
AIC_CORS_ORIGINS=*

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================
# Default cache TTL in seconds
AIC_CACHE_DEFAULT_TTL=300

# LLM response cache TTL
AIC_CACHE_LLM_RESPONSE_TTL=3600

# Bot profile cache TTL
AIC_CACHE_BOT_PROFILE_TTL=300

# =============================================================================
# MONITORING
# =============================================================================
# Enable Prometheus metrics
AIC_METRICS_ENABLED=true

# Metrics endpoint port
AIC_METRICS_PORT=9090

# Health check timeout
AIC_HEALTH_CHECK_TIMEOUT=5.0

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AIC_LOG_LEVEL=INFO

# =============================================================================
# FIREBASE CLOUD MESSAGING (FCM)
# =============================================================================
# Path to Firebase Admin SDK service account credentials JSON file
# Download from Firebase Console > Project Settings > Service Accounts
AIC_FCM_CREDENTIALS_PATH=

# Firebase project ID (found in Firebase Console > Project Settings)
AIC_FCM_PROJECT_ID=

# =============================================================================
# OBJECT STORAGE (Configurable backend)
# =============================================================================
# Storage provider: local, minio, seaweedfs, garage, s3
# Default is local filesystem (free, no setup required)
AIC_STORAGE_PROVIDER=local

# For S3-compatible providers (minio, seaweedfs, garage):
# Endpoint URL (e.g., http://localhost:9000 for MinIO)
# AIC_STORAGE_ENDPOINT=http://localhost:9000

# Access credentials (not needed for local storage)
# AIC_STORAGE_ACCESS_KEY=your-access-key
# AIC_STORAGE_SECRET_KEY=your-secret-key

# Bucket name for storing media files
AIC_STORAGE_BUCKET=hive-media

# AWS region (only for AWS S3)
# AIC_STORAGE_REGION=us-east-1

# Public URL for serving files (CDN, etc.)
# AIC_STORAGE_PUBLIC_URL=https://cdn.example.com

# Use SSL/HTTPS for storage connections
AIC_STORAGE_USE_SSL=true

# Local filesystem storage path (used when STORAGE_PROVIDER=local)
AIC_MEDIA_STORAGE_PATH=./media

# =============================================================================
# TEXT-TO-SPEECH (Optional - disabled by default)
# =============================================================================
# Enable TTS for bot responses
AIC_TTS_ENABLED=false

# TTS provider: edge (free, no API key), openai, elevenlabs
AIC_TTS_PROVIDER=edge

# API key for paid TTS providers (not needed for Edge TTS)
# AIC_TTS_API_KEY=your-api-key

# =============================================================================
# WEB SEARCH (default: DuckDuckGo - free)
# =============================================================================
# Enable web search for bots to research topics
AIC_WEB_SEARCH_ENABLED=true

# Search provider: duckduckgo (free), tavily, serper, brave, bing
AIC_WEB_SEARCH_PROVIDER=duckduckgo

# API key for paid search providers (not needed for DuckDuckGo)
# AIC_WEB_SEARCH_API_KEY=your-api-key

# =============================================================================
# IMAGE GENERATION (Optional - disabled by default)
# =============================================================================
# Enable AI image generation for posts
AIC_IMAGE_GENERATION_ENABLED=false

# Image provider: openai, stability, together, replicate, local
# AIC_IMAGE_GENERATION_PROVIDER=openai

# API key for image generation (required if enabled)
# AIC_IMAGE_GENERATION_API_KEY=your-api-key

# =============================================================================
# EXTERNAL CHANNELS (Telegram, Discord)
# =============================================================================
# Enable external channel integrations (requires tokens below)
AIC_EXTERNAL_CHANNELS_ENABLED=true

# Telegram Bot Token (get from @BotFather)
# AIC_TELEGRAM_BOT_TOKEN=your-bot-token

# Discord Bot Token
# AIC_DISCORD_BOT_TOKEN=your-bot-token

# =============================================================================
# VIDEO PROCESSING
# =============================================================================
# Maximum video file size in MB
AIC_MAX_VIDEO_SIZE_MB=100

# Maximum video duration in seconds
AIC_MAX_VIDEO_DURATION_SECONDS=300

# Allowed video formats (comma-separated)
AIC_VIDEO_FORMATS=mp4,mov,webm

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Deployment environment: development, staging, production, test
AIC_ENVIRONMENT=development

# =============================================================================
# DATABASE POOL (Advanced)
# =============================================================================
# Connection pool size
# AIC_DATABASE_POOL_SIZE=10

# Maximum overflow connections
# AIC_DATABASE_MAX_OVERFLOW=20

# =============================================================================
# REDIS (Advanced)
# =============================================================================
# Maximum Redis connections
# AIC_REDIS_MAX_CONNECTIONS=10

# Enable Redis (disable for simpler deployments)
# AIC_REDIS_ENABLED=true

# =============================================================================
# DATABASE MIGRATIONS (Alembic)
# =============================================================================
# Alembic reads the database URL from AIC_DATABASE_URL above.
#
# Common migration commands:
#   alembic upgrade head              - Apply all pending migrations
#   alembic downgrade -1              - Rollback one migration
#   alembic current                   - Show current revision
#   alembic history                   - Show migration history
#   alembic revision --autogenerate -m "description"  - Generate new migration
#
# Or use the helper script:
#   python scripts/migrate.py upgrade     - Apply all pending migrations
#   python scripts/migrate.py downgrade   - Rollback last migration
#   python scripts/migrate.py generate "description"  - Generate new migration
#   python scripts/migrate.py check       - Test database connection
#
# First-time setup:
#   1. Ensure PostgreSQL is running with the pgvector extension
#   2. Create the database: CREATE DATABASE ai_companions;
#   3. Run migrations: alembic upgrade head
#
# After modifying models in ai_companions/core/database.py:
#   1. Generate migration: alembic revision --autogenerate -m "description"
#   2. Review the generated migration file in alembic/versions/
#   3. Apply migration: alembic upgrade head
